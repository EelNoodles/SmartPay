<%- include('../partials/head') %>
<body class="min-h-screen">
  <%- include('../partials/topbar') %>
  <%- include('../partials/flash') %>

  <main class="container-app py-5 space-y-5">
    <h1 class="text-2xl font-bold"><%= account ? '編輯' : '新增' %>金融工具</h1>

    <form
      action="<%= BASE_PATH %>/accounts<%= account ? '/' + account.id : '' %>"
      method="POST"
      enctype="multipart/form-data"
      class="card space-y-4">

      <div>
        <label class="label">類型</label>
        <div class="grid grid-cols-2 gap-2">
          <% ACCOUNT_TYPE_OPTIONS.forEach(function(opt){
               var checked = account ? account.account_type === opt.value : opt.value === 2; %>
            <label class="cursor-pointer">
              <input type="radio" name="account_type" value="<%= opt.value %>" class="peer sr-only" <%= checked ? 'checked' : '' %> required />
              <div class="border border-slate-200 rounded-2xl p-3 peer-checked:border-brand-500 peer-checked:bg-brand-50 peer-checked:shadow-sm flex items-center gap-2 text-sm font-medium">
                <span class="text-lg"><%= opt.emoji %></span>
                <%= opt.label %>
              </div>
            </label>
          <% }) %>
        </div>
      </div>

      <div>
        <label class="label" for="bank_or_provider_name">發卡行 / 服務商</label>
        <input id="bank_or_provider_name" name="bank_or_provider_name" required class="field"
               value="<%= account ? account.bank_or_provider_name : '' %>"
               placeholder="國泰世華、街口支付、玉山、悠遊付..." />
      </div>

      <div>
        <label class="label" for="card_or_account_name">卡片 / 帳戶名稱</label>
        <input id="card_or_account_name" name="card_or_account_name" required class="field"
               value="<%= account ? account.card_or_account_name : '' %>"
               placeholder="CUBE 卡、數位存款帳戶..." />
      </div>

      <div>
        <label class="label" for="last_four_digits">末四碼 (選填)</label>
        <input id="last_four_digits" name="last_four_digits" class="field" inputmode="numeric" maxlength="4"
               value="<%= account && account.last_four_digits ? account.last_four_digits : '' %>"
               placeholder="1234" />
      </div>

      <div>
        <label class="label" for="image">卡面 / Logo 圖片 (選填)</label>
        <input id="image" name="image" type="file" accept="image/jpeg,image/png,image/webp" class="block w-full text-sm text-slate-600 file:mr-3 file:py-2 file:px-4 file:rounded-2xl file:border-0 file:text-sm file:font-semibold file:bg-brand-50 file:text-brand-700 hover:file:bg-brand-100" />
        <% if (account && account.image_path) { %>
          <div class="mt-3 payment-card max-w-xs">
            <img src="<%= BASE_PATH %><%= account.image_path %>" alt="current" />
          </div>
          <p class="text-[11px] text-slate-400 mt-2">目前卡面（重新上傳將取代此圖）</p>
        <% } %>
        <p class="text-[11px] text-slate-400 mt-2">建議 1920×1080（16:9），JPEG / PNG / WEBP ≦ 5MB。</p>
      </div>

      <div class="flex gap-3 pt-2">
        <a href="<%= BASE_PATH %>/accounts" class="btn-ghost flex-1">取消</a>
        <button type="submit" class="btn-primary flex-1"><%= account ? '儲存' : '新增' %></button>
      </div>
    </form>

    <% if (account) { %>
      <form action="<%= BASE_PATH %>/accounts/<%= account.id %>/delete" method="POST" onsubmit="return confirm('確定刪除此金融工具？關聯活動將一併刪除。');">
        <button type="submit" class="btn-danger w-full">刪除</button>
      </form>
    <% } %>
  </main>

  <%- include('../partials/foot') %>
