<%- include('../partials/head') %>
<body class="min-h-screen">
  <%- include('../partials/topbar') %>
  <%- include('../partials/flash') %>

  <main class="container-app py-5 space-y-6">
    <div class="flex items-center justify-between animate-fade-up">
      <div>
        <h1 class="text-2xl font-extrabold">金融工具</h1>
        <p class="text-xs text-slate-500 mt-0.5">管理你所有的銀行帳戶、信用卡與行動支付</p>
      </div>
      <a href="<%= BASE_PATH %>/accounts/new" class="btn-primary !py-2 !px-4 text-xs">+ 新增</a>
    </div>

    <% Object.keys(grouped).forEach(function(typeId){
         var meta = ACCOUNT_TYPE_META[typeId];
         var list = grouped[typeId] || []; if (!meta) return; %>
      <section data-reveal>
        <h2 class="text-sm font-semibold text-slate-600 mb-2 flex items-center gap-2">
          <span class="w-6 h-6 rounded-lg flex items-center justify-center <%= meta.accent %> text-white text-xs shadow-card"><%= meta.emoji %></span>
          <%= meta.label %> <span class="text-slate-400 font-normal">(<%= list.length %>)</span>
        </h2>
        <% if (list.length === 0) { %>
          <div class="card text-sm text-slate-400 py-4 text-center border border-dashed border-slate-200">尚未新增</div>
        <% } else { %>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <% list.forEach(function(a, idx){ %>
              <a href="<%= BASE_PATH %>/accounts/<%= a.id %>" data-reveal class="block group">
                <div class="payment-card <%= a.image_path ? '' : 'payment-card-ghost' %>">
                  <% if (a.image_path) { %>
                    <img src="<%= BASE_PATH %><%= a.image_path %>"
                         alt="<%= a.card_or_account_name %>"
                         class="transition-transform duration-500 group-hover:scale-[1.04]" />
                  <% } else { %>
                    <span class="watermark"><%= meta.emoji %></span>
                    <div class="absolute inset-0 p-4 flex flex-col justify-between text-white z-[3]">
                      <div class="flex items-center justify-between">
                        <span class="text-[11px] uppercase tracking-widest opacity-80"><%= meta.label %></span>
                        <span class="text-[11px] opacity-90"><%= a.bank_or_provider_name %></span>
                      </div>
                      <div>
                        <p class="font-semibold"><%= a.card_or_account_name %></p>
                        <p class="text-xs opacity-80 tracking-[0.3em] mt-1">•••• <%= a.last_four_digits || '----' %></p>
                      </div>
                    </div>
                  <% } %>
                </div>
                <div class="mt-3 px-1 flex items-center justify-between gap-3">
                  <div class="min-w-0">
                    <p class="font-semibold truncate"><%= a.card_or_account_name %></p>
                    <p class="text-xs text-slate-500 truncate"><%= a.bank_or_provider_name %> · •••• <%= a.last_four_digits || '----' %></p>
                  </div>
                  <span class="chip-slate shrink-0"><%= meta.label %></span>
                </div>
              </a>
            <% }) %>
          </div>
        <% } %>
      </section>
    <% }) %>
  </main>

  <%- include('../partials/foot') %>
