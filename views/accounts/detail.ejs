<%- include('../partials/head') %>
<body class="min-h-screen">
  <%- include('../partials/topbar') %>
  <%- include('../partials/flash') %>

  <% var meta = ACCOUNT_TYPE_META[account.account_type] || { label: '—', accent: 'bg-slate-500' }; %>

  <main class="container-app py-5 space-y-5">
    <a href="<%= BASE_PATH %>/accounts" class="text-sm text-slate-500 hover:text-brand-600">← 返回清單</a>

    <div class="payment-card max-w-lg animate-fade-up <%= account.image_path ? '' : 'payment-card-ghost' %>">
      <% if (account.image_path) { %>
        <img src="<%= BASE_PATH %><%= account.image_path %>" alt="<%= account.card_or_account_name %>" />
      <% } else { %>
        <span class="watermark"><%= meta.emoji %></span>
        <div class="absolute inset-0 p-5 flex flex-col justify-between text-white z-[3]">
          <div class="flex items-center justify-between">
            <span class="text-[11px] uppercase tracking-widest opacity-90"><%= meta.label %></span>
            <span class="text-[11px] opacity-90"><%= account.bank_or_provider_name %></span>
          </div>
          <div>
            <p class="text-xl font-bold"><%= account.card_or_account_name %></p>
            <p class="text-sm opacity-80 tracking-[0.3em] mt-1">•••• <%= account.last_four_digits || '----' %></p>
          </div>
        </div>
      <% } %>
    </div>

    <div class="max-w-lg flex items-start justify-between gap-3 px-1">
      <div class="min-w-0">
        <p class="text-lg font-extrabold truncate"><%= account.card_or_account_name %></p>
        <p class="text-xs text-slate-500 truncate"><%= account.bank_or_provider_name %> · •••• <%= account.last_four_digits || '----' %></p>
      </div>
      <span class="chip-brand shrink-0 inline-flex items-center gap-1"><%= meta.emoji %> <%= meta.label %></span>
    </div>

    <div class="flex gap-3">
      <a href="<%= BASE_PATH %>/accounts/<%= account.id %>/edit" class="btn-ghost flex-1">編輯</a>
      <a href="<%= BASE_PATH %>/campaigns/new?account=<%= account.id %>" class="btn-primary flex-1">+ 新增活動</a>
    </div>

    <section>
      <h2 class="font-bold text-lg mb-3">此工具的回饋活動</h2>
      <% if (campaigns.length === 0) { %>
        <div class="card text-sm text-slate-500 text-center py-5">尚未有活動，點擊上方新增。</div>
      <% } else { %>
        <div class="space-y-2.5">
          <% campaigns.forEach(function(c){ %>
            <div class="card !p-4">
              <div class="flex items-start justify-between">
                <div>
                  <p class="font-semibold"><%= c.campaign_name %></p>
                  <p class="text-xs text-slate-500 mt-0.5">
                    <%= c.start_date || '—' %> ~ <%= c.end_date || '—' %>
                  </p>
                </div>
                <span class="chip-brand"><%= Number(c.reward_rate).toFixed(2) %>%</span>
              </div>
              <div class="flex flex-wrap gap-1.5 mt-2">
                <% if (c.min_spend_amount) { %><span class="chip-slate">低消 NT$<%= c.min_spend_amount %></span><% } %>
                <% if (c.reward_cap_amount) { %><span class="chip-slate">上限 NT$<%= c.reward_cap_amount %></span><% } %>
                <% if (c.requires_registration) { %><span class="chip-amber">需登錄</span><% } %>
                <% if (c.is_quota_limited) { %><span class="chip-rose">有名額限制</span><% } %>
                <% if (c.requires_plan_switch) { %>
                  <span class="chip-amber">🔄 切換方案<%= c.required_plan_name ? '：' + c.required_plan_name : '' %></span>
                <% } %>
              </div>
              <div class="mt-3 flex justify-end">
                <a href="<%= BASE_PATH %>/campaigns/<%= c.id %>/edit" class="text-xs text-brand-600 hover:text-brand-700 font-semibold">編輯</a>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>
    </section>
  </main>

  <%- include('../partials/foot') %>
