<%- include('../partials/head') %>
<body class="min-h-screen">
  <%- include('../partials/topbar') %>
  <%- include('../partials/flash') %>

  <!-- ===== AI Loading Overlay ===== -->
  <div id="ai-overlay" aria-hidden="true" style="
    display:none; position:fixed; inset:0; z-index:9999;
    background:rgba(15,23,42,0.72); backdrop-filter:blur(6px);
    -webkit-backdrop-filter:blur(6px);
    align-items:center; justify-content:center; flex-direction:column;
    animation:fadeIn .25s ease both;
  ">
    <!-- Glowing card -->
    <div style="
      background:linear-gradient(135deg,#1a2d82,#111d5c);
      border-radius:2rem; padding:2rem 2.5rem;
      box-shadow:0 0 0 1px rgba(95,132,255,.3), 0 24px 60px rgba(17,29,92,.6);
      text-align:center; max-width:320px; width:90%;
    ">
      <!-- Animated rings -->
      <div id="ai-rings" style="position:relative;width:72px;height:72px;margin:0 auto 1.5rem;">
        <div style="
          position:absolute;inset:0;border-radius:50%;
          border:3px solid rgba(95,132,255,.25);
        "></div>
        <div id="ring-spin" style="
          position:absolute;inset:0;border-radius:50%;
          border:3px solid transparent;
          border-top-color:#5f84ff;
          animation:spin 1s linear infinite;
        "></div>
        <div style="
          position:absolute;inset:8px;border-radius:50%;
          border:2px solid transparent;
          border-top-color:#a5b4fc;
          animation:spin .7s linear infinite reverse;
        "></div>
        <div style="
          position:absolute;inset:18px;border-radius:50%;
          background:linear-gradient(135deg,#3b63f5,#1f38a8);
          display:flex;align-items:center;justify-content:center;
        ">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" style="color:#fff">
            <path d="M12 3c-4.97 0-9 4.03-9 9s4.03 9 9 9 9-4.03 9-9"
              stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
            <path d="M12 8v4l3 3" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
      </div>

      <!-- Stage label -->
      <p id="ai-stage-label" style="
        color:#a5b4fc; font-size:11px; font-weight:600;
        letter-spacing:.08em; text-transform:uppercase; margin-bottom:.5rem;
      ">準備中</p>
      <p id="ai-stage-msg" style="
        color:#fff; font-size:.9rem; font-weight:700; margin-bottom:1.25rem; line-height:1.4;
      ">正在啟動 AI 引擎…</p>

      <!-- Progress bar + timer -->
      <div style="background:rgba(255,255,255,.1);border-radius:999px;height:6px;overflow:hidden;margin-bottom:.75rem;">
        <div id="ai-progress-bar" style="
          height:100%;width:0%;border-radius:999px;
          background:linear-gradient(90deg,#5f84ff,#a5b4fc);
          transition:width .6s ease;
        "></div>
      </div>
      <p id="ai-timer" style="color:rgba(165,180,252,.7);font-size:11px;">0s / 30s 上限</p>

      <!-- Stages list -->
      <div style="margin-top:1.25rem;display:flex;flex-direction:column;gap:.5rem;text-align:left;">
        <div id="stage-item-0" class="ai-stage-item" style="display:flex;align-items:center;gap:.75rem;padding:.5rem .75rem;border-radius:999px;background:rgba(255,255,255,.06);">
          <span class="stage-icon" style="width:18px;height:18px;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:13px;">⏳</span>
          <span style="color:rgba(255,255,255,.7);font-size:12px;font-weight:500;">讀取金融工具資料</span>
        </div>
        <div id="stage-item-1" class="ai-stage-item" style="display:flex;align-items:center;gap:.75rem;padding:.5rem .75rem;border-radius:999px;background:rgba(255,255,255,.06);">
          <span class="stage-icon" style="width:18px;height:18px;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:13px;">⏳</span>
          <span style="color:rgba(255,255,255,.7);font-size:12px;font-weight:500;">詢問 AI 運算最佳組合</span>
        </div>
        <div id="stage-item-2" class="ai-stage-item" style="display:flex;align-items:center;gap:.75rem;padding:.5rem .75rem;border-radius:999px;background:rgba(255,255,255,.06);">
          <span class="stage-icon" style="width:18px;height:18px;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:13px;">⏳</span>
          <span style="color:rgba(255,255,255,.7);font-size:12px;font-weight:500;">整理並呈現推薦結果</span>
        </div>
      </div>
    </div>
  </div>

  <style>
    @keyframes fadeIn { from{opacity:0;transform:scale(.96)} to{opacity:1;transform:scale(1)} }
    @keyframes spin   { to{transform:rotate(360deg)} }
    .ai-stage-item.done   { background:rgba(16,185,129,.15) !important; }
    .ai-stage-item.done   .stage-icon::after   { content:'✅'; }
    .ai-stage-item.done   .stage-icon          { font-size:0; }
    .ai-stage-item.active { background:rgba(95,132,255,.2) !important; }
    .ai-stage-item.active .stage-icon::after   { content:'🔄'; }
    .ai-stage-item.active .stage-icon          { font-size:0; animation:spin .9s linear infinite; }
  </style>

  <main class="container-app py-5 space-y-6">
    <!-- Input card -->
    <section class="relative overflow-hidden rounded-3xl bg-gradient-to-br from-brand-600 via-brand-700 to-brand-900 text-white p-6 shadow-glow animate-fade-up">
      <div class="hero-blob bg-sky-400/60 w-56 h-56 -top-10 -left-16 animate-blob"></div>
      <div class="hero-blob bg-indigo-400/60 w-72 h-72 -bottom-24 -right-16 animate-blob animation-delay-300"></div>

      <div class="relative">
        <p class="chip bg-white/20 text-white border border-white/25 inline-flex">✨ AI Recommender</p>
        <h1 class="text-2xl sm:text-3xl font-extrabold mt-2 text-white">最佳支付試算</h1>
        <form id="recommender-form" class="mt-5 space-y-3" autocomplete="off">
          <div>
            <label class="label text-white/80" for="scenario">消費情境 / 店家</label>
            <input id="scenario" name="scenario" required class="field !bg-white/95 text-slate-900"
                   value="<%= query.scenario %>" placeholder="例：全聯 買菜、星巴克、蝦皮購物" />
          </div>
          <div>
            <label class="label text-white/80" for="amount">預計消費金額 (NT$)</label>
            <input id="amount" name="amount" type="number" min="1" required inputmode="numeric" class="field !bg-white/95 text-slate-900"
                   value="<%= query.amount %>" placeholder="1500" />
          </div>
          <button id="submit-btn" type="submit" class="btn w-full bg-white text-brand-700 hover:bg-white/95 font-bold">
            <span class="spinner hidden"></span>
            <span class="btn-text">試算最佳支付</span>
          </button>
        </form>
      </div>
    </section>

    <% if (accounts.length === 0) { %>
      <div class="card text-center py-6 animate-fade-up">
        <p class="text-sm text-slate-500">你還沒有任何金融工具。</p>
        <a href="<%= BASE_PATH %>/accounts/new" class="btn-primary mt-4 inline-flex">先新增一張卡</a>
      </div>
    <% } %>

    <!-- Result area (動態注入) -->
    <div id="result-area">
      <% if (result && result.error) { %>
        <div class="card bg-rose-50 border border-rose-200 text-rose-700 text-sm animate-fade-up"><%= result.error %></div>
      <% } %>

      <% if (result && result.recommendations && result.recommendations.length) {
           var maxReward = 0;
           result.recommendations.forEach(function(r){ if (Number(r.estimated_reward||0) > maxReward) maxReward = Number(r.estimated_reward||0); });
           if (maxReward === 0) maxReward = 1;
      %>
        <section>
          <div class="flex items-center justify-between mb-3">
            <h2 class="font-bold text-lg flex items-center gap-2">
              <span class="text-xl">🏆</span> Leaderboard
              <span class="chip-brand"><%= result.recommendations.length %> 名</span>
            </h2>
            <span class="text-[11px] text-slate-500 inline-flex items-center gap-1">
              <% if (result.context && result.context.usedCache) { %>
                <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse-soft"></span> context cache
              <% } else { %>
                <span class="w-2 h-2 rounded-full bg-brand-500"></span> direct
              <% } %>
            </span>
          </div>
          <div class="space-y-3">
            <% result.recommendations.forEach(function(r, idx){
                 var meta = r.account ? ACCOUNT_TYPE_META[r.account.account_type] : null;
                 var reward = Number(r.estimated_reward || 0);
                 var rate   = Number(r.estimated_rate || 0);
                 var pct = Math.max(6, Math.round((reward / maxReward) * 100));
                 var isTop = r.rank === 1;
            %>
              <article data-reveal class="relative card !p-5 <%= isTop ? 'ring-2 ring-amber-300/70 bg-gradient-to-br from-amber-50/80 to-white' : '' %>">
                <% if (isTop) { %>
                  <span class="absolute -top-2 -left-2 chip bg-gradient-to-r from-amber-400 to-amber-600 text-white shadow-card px-2.5 py-1 text-[11px]">
                    👑 最推薦
                  </span>
                <% } %>
                <div class="flex items-start gap-4">
                  <div class="rank-<%= r.rank %>"><%= r.rank %></div>
                  <div class="min-w-0 flex-1">
                    <p class="text-xs text-slate-500"><%= meta ? meta.label : '—' %></p>
                    <p class="font-extrabold text-lg truncate"><%= r.payment_label %></p>
                    <% if (r.account) { %>
                      <p class="text-xs text-slate-500 truncate"><%= r.account.bank_or_provider_name %> · •••• <%= r.account.last_four_digits || '----' %></p>
                    <% } %>
                  </div>
                  <div class="text-right">
                    <p class="text-[11px] text-slate-500">預估回饋</p>
                    <p class="text-2xl font-black <%= isTop ? 'text-amber-700' : 'text-brand-700' %>">
                      <span data-countup="<%= Math.round(reward) %>" data-countup-prefix="$" data-countup-duration="900">$0</span>
                    </p>
                    <p class="text-[11px] text-slate-500"><%= rate.toFixed(2) %>%</p>
                  </div>
                </div>
                <div class="mt-4 h-2 w-full bg-slate-100 rounded-full overflow-hidden">
                  <div class="h-full <%= isTop ? 'bg-gradient-to-r from-amber-400 to-amber-600' : 'bg-gradient-to-r from-brand-400 to-brand-700' %> transition-all duration-700"
                       style="width: <%= pct %>%"></div>
                </div>
                <% if ((r.warnings || []).length) { %>
                  <ul class="mt-4 space-y-1.5">
                    <% r.warnings.forEach(function(w){ %>
                      <li class="text-xs text-amber-700 bg-amber-50 border border-amber-200 rounded-xl px-3 py-2 flex items-start gap-2">
                        <svg class="w-4 h-4 flex-shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 9v4M12 17h0M10.3 3.9L1.8 18.1a2 2 0 0 0 1.7 3h17a2 2 0 0 0 1.7-3L13.7 3.9a2 2 0 0 0-3.4 0z" stroke-linejoin="round"/></svg>
                        <span><%= w %></span>
                      </li>
                    <% }) %>
                  </ul>
                <% } %>
                <% if (r.reasoning) { %>
                  <p class="text-xs text-slate-600 mt-3 leading-relaxed border-t border-slate-100 pt-3"><%= r.reasoning %></p>
                <% } %>
              </article>
            <% }) %>
          </div>
        </section>
      <% } else if (result && !result.error) { %>
        <div class="card text-center py-6 text-sm text-slate-500 animate-fade-up">
          沒有可用推薦。請新增金融工具或活動後再試。
        </div>
      <% } %>
    </div>
  </main>

  <%- include('../partials/foot') %>

  <script>
  (function () {
    'use strict';

    var BASE_PATH = '<%= BASE_PATH %>';
    var ACCOUNT_TYPE_META = <%- JSON.stringify(ACCOUNT_TYPE_META) %>;

    // ────────────────────────────────────────────────
    // Loading overlay helpers
    // ────────────────────────────────────────────────
    var overlay  = document.getElementById('ai-overlay');
    var stageLabel = document.getElementById('ai-stage-label');
    var stageMsg   = document.getElementById('ai-stage-msg');
    var progressBar = document.getElementById('ai-progress-bar');
    var timerEl    = document.getElementById('ai-timer');
    var stageItems = [
      document.getElementById('stage-item-0'),
      document.getElementById('stage-item-1'),
      document.getElementById('stage-item-2'),
    ];

    var timerInterval = null;
    var startTime = 0;
    var TIMEOUT_S = 60;

    var STAGES = [
      { label: '讀取資料', msg: '正在讀取您的金融工具與活動資料…', pct: 20 },
      { label: '詢問 AI',  msg: '正在詢問 AI 分析最佳支付組合，請稍候…', pct: 55 },
      { label: '整理結果', msg: '正在整理 AI 回應並計算回饋金額…', pct: 85 },
    ];

    function showOverlay() {
      // Reset
      stageItems.forEach(function (el) { el.className = 'ai-stage-item'; });
      progressBar.style.width = '0%';
      timerEl.textContent = '0s / ' + TIMEOUT_S + 's 上限';
      overlay.style.display = 'flex';
      document.body.style.overflow = 'hidden';

      startTime = Date.now();
      timerInterval = setInterval(function () {
        var elapsed = Math.round((Date.now() - startTime) / 1000);
        var remaining = TIMEOUT_S - elapsed;
        timerEl.textContent = elapsed + 's / ' + TIMEOUT_S + 's 上限';
        // Warn colour when close to timeout
        if (remaining <= 8) {
          timerEl.style.color = 'rgba(252,165,165,.9)';
        }
      }, 500);

      setStage(0);
    }

    function setStage(idx) {
      // Mark previous done
      for (var i = 0; i < idx; i++) {
        stageItems[i].className = 'ai-stage-item done';
      }
      // Mark current active
      if (idx < stageItems.length) {
        stageItems[idx].className = 'ai-stage-item active';
        stageLabel.textContent = STAGES[idx].label;
        stageMsg.textContent   = STAGES[idx].msg;
        progressBar.style.width = STAGES[idx].pct + '%';
      }
    }

    function hideOverlay() {
      clearInterval(timerInterval);
      progressBar.style.width = '100%';
      stageItems.forEach(function (el) { el.className = 'ai-stage-item done'; });
      setTimeout(function () {
        overlay.style.display = 'none';
        document.body.style.overflow = '';
        timerEl.style.color = 'rgba(165,180,252,.7)';
      }, 400);
    }

    // ────────────────────────────────────────────────
    // Result renderer
    // ────────────────────────────────────────────────
    function escHtml(str) {
      return String(str || '')
        .replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
        .replace(/"/g,'&quot;').replace(/'/g,'&#39;');
    }

    function renderResults(data) {
      var area = document.getElementById('result-area');

      if (data.error) {
        area.innerHTML =
          '<div class="card bg-rose-50 border border-rose-200 text-rose-700 text-sm animate-fade-up">' +
          escHtml(data.error) + '</div>';
        return;
      }

      var recs = data.recommendations || [];
      if (!recs.length) {
        area.innerHTML =
          '<div class="card text-center py-6 text-sm text-slate-500 animate-fade-up">' +
          '沒有可用推薦。請新增金融工具或活動後再試。</div>';
        return;
      }

      var maxReward = 0;
      recs.forEach(function (r) { if (Number(r.estimated_reward||0) > maxReward) maxReward = Number(r.estimated_reward||0); });
      if (maxReward === 0) maxReward = 1;

      var usedCache = data.context && data.context.usedCache;
      var cacheHtml = usedCache
        ? '<span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse-soft" style="display:inline-block;width:8px;height:8px;border-radius:50%;background:#10b981;"></span> context cache'
        : '<span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:#3b63f5;"></span> direct';

      var html = '<section><div class="flex items-center justify-between mb-3">' +
        '<h2 class="font-bold text-lg flex items-center gap-2">' +
        '<span class="text-xl">🏆</span> Leaderboard ' +
        '<span class="chip-brand">' + recs.length + ' 名</span></h2>' +
        '<span class="text-[11px] text-slate-500 inline-flex items-center gap-1">' + cacheHtml + '</span>' +
        '</div><div class="space-y-3">';

      recs.forEach(function (r) {
        var meta   = r.account ? ACCOUNT_TYPE_META[r.account.account_type] : null;
        var reward = Number(r.estimated_reward || 0);
        var rate   = Number(r.estimated_rate || 0);
        var pct    = Math.max(6, Math.round((reward / maxReward) * 100));
        var isTop  = r.rank === 1;

        var barClass = isTop
          ? 'background:linear-gradient(90deg,#fbbf24,#d97706)'
          : 'background:linear-gradient(90deg,#5f84ff,#1f38a8)';
        var rewardColor = isTop ? 'color:#b45309' : 'color:#1f38a8';
        var cardClass = isTop
          ? 'card !p-5 ring-2 ring-amber-300/70 bg-gradient-to-br from-amber-50/80 to-white'
          : 'card !p-5';

        var crownBadge = isTop
          ? '<span class="absolute -top-2 -left-2 chip" style="background:linear-gradient(90deg,#fbbf24,#d97706);color:#fff;box-shadow:0 4px 12px rgba(17,29,92,.15);padding:.25rem .625rem;font-size:11px;">👑 最推薦</span>'
          : '';

        var accountSub = r.account
          ? '<p class="text-xs text-slate-500 truncate">' + escHtml(r.account.bank_or_provider_name) +
            ' · •••• ' + escHtml(r.account.last_four_digits || '----') + '</p>'
          : '';

        var warningsHtml = '';
        (r.warnings || []).forEach(function (w) {
          warningsHtml +=
            '<li class="text-xs text-amber-700 bg-amber-50 border border-amber-200 rounded-xl px-3 py-2 flex items-start gap-2">' +
            '<svg class="w-4 h-4 flex-shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 9v4M12 17h0M10.3 3.9L1.8 18.1a2 2 0 0 0 1.7 3h17a2 2 0 0 0 1.7-3L13.7 3.9a2 2 0 0 0-3.4 0z" stroke-linejoin="round"/></svg>' +
            '<span>' + escHtml(w) + '</span></li>';
        });

        var reasoningHtml = r.reasoning
          ? '<p class="text-xs text-slate-600 mt-3 leading-relaxed border-t border-slate-100 pt-3">' + escHtml(r.reasoning) + '</p>'
          : '';

        html +=
          '<article data-reveal class="relative ' + cardClass + '">' +
          crownBadge +
          '<div class="flex items-start gap-4">' +
          '<div class="rank-' + r.rank + '">' + r.rank + '</div>' +
          '<div class="min-w-0 flex-1">' +
          '<p class="text-xs text-slate-500">' + escHtml(meta ? meta.label : '—') + '</p>' +
          '<p class="font-extrabold text-lg truncate">' + escHtml(r.payment_label) + '</p>' +
          accountSub +
          '</div>' +
          '<div class="text-right">' +
          '<p class="text-[11px] text-slate-500">預估回饋</p>' +
          '<p class="text-2xl font-black" style="' + rewardColor + '">' +
          '<span data-countup="' + Math.round(reward) + '" data-countup-prefix="$" data-countup-duration="900">$0</span>' +
          '</p>' +
          '<p class="text-[11px] text-slate-500">' + rate.toFixed(2) + '%</p>' +
          '</div></div>' +
          '<div class="mt-4 h-2 w-full bg-slate-100 rounded-full overflow-hidden">' +
          '<div class="h-full transition-all duration-700" style="width:' + pct + '%;' + barClass + '"></div>' +
          '</div>' +
          (warningsHtml ? '<ul class="mt-4 space-y-1.5">' + warningsHtml + '</ul>' : '') +
          reasoningHtml +
          '</article>';
      });

      html += '</div></section>';
      area.innerHTML = html;

      // Trigger animations + count-up
      if (window.SmartPay) {
        window.SmartPay.initReveal(area);
      }
      // Scroll into view
      area.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    // ────────────────────────────────────────────────
    // Form submit handler
    // ────────────────────────────────────────────────
    var form = document.getElementById('recommender-form');
    var submitBtn = document.getElementById('submit-btn');
    var activeController = null;

    form.addEventListener('submit', function (e) {
      e.preventDefault();

      var scenario = (document.getElementById('scenario').value || '').trim();
      var amount   = Number(document.getElementById('amount').value || 0);
      if (!scenario || !amount || amount <= 0) return;

      // ── Cancel any previous in-flight request
      if (activeController) { activeController.abort(); }
      activeController = new AbortController();
      var signal = activeController.signal;

      // ── UI: start loading
      submitBtn.disabled = true;
      submitBtn.classList.add('is-loading');
      showOverlay();

      // ── Stage 0: fetching data (simulate 0.8s before AI call)
      setStage(0);

      // ── Stage 1 after tiny delay to let stage 0 animate
      var stage1Timer = setTimeout(function () { setStage(1); }, 800);

      // ── Timeout stage message update (25s → warn)
      var warnTimer = setTimeout(function () {
        stageMsg.textContent = 'AI 仍在思考中，最多等待 60 秒…';
      }, 50000);

      fetch(BASE_PATH + '/recommender/api', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify({ scenario: scenario, amount: amount }),
        signal: signal
      })
      .then(function (res) {
        clearTimeout(stage1Timer);
        clearTimeout(warnTimer);
        setStage(2); // Organising results
        return res.json().then(function (data) {
          return { ok: res.ok, status: res.status, data: data };
        });
      })
      .then(function (result) {
        // Short pause so "整理結果" stage is visible
        setTimeout(function () {
          hideOverlay();
          submitBtn.disabled = false;
          submitBtn.classList.remove('is-loading');
          renderResults(result.data);
          activeController = null;
        }, 600);
      })
      .catch(function (err) {
        clearTimeout(stage1Timer);
        clearTimeout(warnTimer);
        hideOverlay();
        submitBtn.disabled = false;
        submitBtn.classList.remove('is-loading');
        activeController = null;

        if (err.name === 'AbortError') return; // 使用者取消，不顯示訊息

        renderResults({
          error: err.message || '網路錯誤，請稍後再試。'
        });
      });
    });

  })();
  </script>
</body>
</html>
