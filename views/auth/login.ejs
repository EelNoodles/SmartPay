<%- include('../partials/head') %>
<body class="min-h-screen bg-gradient-to-br from-brand-50 via-white to-brand-100">
  <main class="min-h-screen flex items-center justify-center px-5 py-10">
    <div class="w-full max-w-sm">
      <div class="flex flex-col items-center mb-8">
        <div class="w-14 h-14 rounded-3xl bg-gradient-to-br from-brand-500 to-brand-700 flex items-center justify-center text-white font-black text-2xl shadow-card">S</div>
        <h1 class="mt-4 text-2xl font-bold">SmartPay</h1>
        <p class="text-sm text-slate-500 mt-1">你的智能支付管家</p>
      </div>

      <%- include('../partials/flash') %>

      <form action="<%= BASE_PATH %>/auth/login" method="POST" class="card space-y-4">
        <div>
          <label class="label" for="username">帳號</label>
          <input id="username" name="username" type="text" required autocomplete="username"
                 value="<%= form.username %>" class="field" placeholder="your_username" />
        </div>
        <div>
          <label class="label" for="password">密碼</label>
          <input id="password" name="password" type="password" required autocomplete="current-password" class="field" placeholder="••••••••" />
        </div>
        <button type="submit" class="btn-primary w-full">登入</button>
      </form>

      <p class="text-center text-sm text-slate-500 mt-6">
        還沒有帳號？
        <a href="<%= BASE_PATH %>/auth/register" class="font-semibold text-brand-600 hover:text-brand-700">立即註冊</a>
      </p>
    </div>
  </main>
</body>
</html>
