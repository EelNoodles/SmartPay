<%- include('partials/head') %>
<body class="min-h-screen">
  <main class="min-h-screen flex items-center justify-center px-6">
    <div class="card max-w-md text-center">
      <h1 class="text-2xl font-bold"><%= typeof title !== 'undefined' ? title : 'Oops' %></h1>
      <p class="text-sm text-slate-500 mt-2"><%= message || '發生未預期的錯誤。' %></p>
      <a href="<%= BASE_PATH %>/" class="btn-primary mt-5 inline-flex">回首頁</a>
    </div>
  </main>
</body>
</html>
