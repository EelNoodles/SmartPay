<header class="sticky top-0 z-30 bg-white/70 backdrop-blur-xl border-b border-white/60">
  <div class="container-app flex items-center justify-between py-3">
    <a href="<%= BASE_PATH %>/" class="flex items-center gap-2">
      <span class="w-9 h-9 rounded-2xl bg-gradient-to-br from-brand-500 to-brand-700 text-white flex items-center justify-center shadow-card font-black">S</span>
      <span class="font-display font-bold text-slate-900 text-lg tracking-tight">SmartPay</span>
    </a>
    <% if (currentUser) { %>
      <div class="flex items-center gap-2">
        <span class="hidden sm:inline text-xs text-slate-500"><%= currentUser.display_name || currentUser.username %></span>
        <form action="<%= BASE_PATH %>/auth/logout" method="POST">
          <button type="submit" class="text-xs px-3 py-1.5 rounded-full bg-slate-100 hover:bg-slate-200 text-slate-600 font-semibold">登出</button>
        </form>
      </div>
    <% } %>
  </div>
</header>
