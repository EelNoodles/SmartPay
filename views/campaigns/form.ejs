<%- include('../partials/head') %>
<body class="min-h-screen">
  <%- include('../partials/topbar') %>
  <%- include('../partials/flash') %>

  <main class="container-app py-5 space-y-5">
    <div class="animate-fade-up">
      <h1 class="text-2xl font-extrabold">AI 智能登錄活動</h1>
      <p class="text-sm text-slate-500 mt-1">貼上官方冗長活動規則，讓 Gemini 幫你一鍵抽取為結構化資料。</p>
    </div>

    <!-- Step 1: paste + AI parse -->
    <div class="card space-y-3 animate-fade-up animation-delay-75">
      <label class="label" for="raw_text">① 貼上活動規則原文</label>
      <textarea id="raw_text" rows="7" class="field font-mono text-[13px]" placeholder="範例：2026/01/01 - 2026/06/30，週一至週五於全家、7-11 消費滿 100 元，使用 XX 卡享 8% 回饋，每月最高 300 元，需先至官網登錄..."></textarea>
      <div class="flex items-center justify-between">
        <p id="parseStatus" class="text-xs text-slate-500">貼上後按右側按鈕</p>
        <button id="btnParse" type="button" class="btn-primary !py-2 !px-4 text-sm">
          <span id="btnParseSpinner" class="spinner hidden"></span>
          <span class="btn-text inline-flex items-center gap-2">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 3v3M12 18v3M3 12h3M18 12h3M5.6 5.6l2.1 2.1M16.3 16.3l2.1 2.1M5.6 18.4l2.1-2.1M16.3 7.7l2.1-2.1" stroke-linecap="round"/></svg>
            AI 抽取欄位
          </span>
        </button>
      </div>
    </div>

    <!-- Step 2: confirm form -->
    <form id="saveForm" action="<%= BASE_PATH %>/campaigns" method="POST" class="card space-y-4 animate-fade-up animation-delay-150" data-loading>
      <h2 class="font-bold">② 確認並儲存</h2>

      <div>
        <label class="label" for="financial_account_id">綁定金融工具</label>
        <select id="financial_account_id" name="financial_account_id" required class="field">
          <option value="">請選擇</option>
          <% accounts.forEach(function(a){ %>
            <option value="<%= a.id %>"><%= a.card_or_account_name %> (<%= a.bank_or_provider_name %>)</option>
          <% }) %>
        </select>
      </div>

      <div>
        <label class="label" for="campaign_name">活動名稱</label>
        <input id="campaign_name" name="campaign_name" required class="field" />
      </div>

      <div class="grid grid-cols-2 gap-3">
        <div>
          <label class="label" for="start_date">開始日期</label>
          <input id="start_date" name="start_date" type="date" class="field" />
        </div>
        <div>
          <label class="label" for="end_date">結束日期</label>
          <input id="end_date" name="end_date" type="date" class="field" />
        </div>
      </div>

      <div class="grid grid-cols-2 gap-3">
        <div>
          <label class="label" for="reward_rate">回饋 %</label>
          <input id="reward_rate" name="reward_rate" type="number" step="0.01" min="0" class="field" />
        </div>
        <div>
          <label class="label" for="min_spend_amount">最低消費 (NT$)</label>
          <input id="min_spend_amount" name="min_spend_amount" type="number" min="0" class="field" />
        </div>
      </div>

      <div class="grid grid-cols-2 gap-3">
        <div>
          <label class="label" for="reward_cap_amount">回饋上限金額</label>
          <input id="reward_cap_amount" name="reward_cap_amount" type="number" min="0" class="field" />
        </div>
        <div>
          <label class="label" for="reward_cap_period">上限週期</label>
          <select id="reward_cap_period" name="reward_cap_period" class="field">
            <% REWARD_CAP_PERIOD_OPTIONS.forEach(function(o){ %>
              <option value="<%= o.value %>"><%= o.label %></option>
            <% }) %>
          </select>
        </div>
      </div>

      <div>
        <label class="label">適用星期 (不勾=全週)</label>
        <div class="flex flex-wrap gap-2">
          <% WEEKDAYS.forEach(function(w){ %>
            <label class="cursor-pointer">
              <input type="checkbox" name="applicable_days" value="<%= w.value %>" class="peer sr-only day-chk" data-day="<%= w.value %>" />
              <span class="chip-slate peer-checked:!bg-brand-600 peer-checked:!text-white px-3 py-1.5 text-xs"><%= w.label %></span>
            </label>
          <% }) %>
        </div>
      </div>

      <div>
        <label class="label" for="target_merchants">指定通路 / 店家 (以逗號或換行分隔)</label>
        <textarea id="target_merchants" name="target_merchants" rows="2" class="field" placeholder="全家, 7-11, 蝦皮"></textarea>
      </div>

      <div class="flex flex-wrap items-center gap-x-6 gap-y-3 pt-1">
        <label class="inline-flex items-center gap-2 text-sm">
          <input type="checkbox" id="requires_registration" name="requires_registration" class="w-4 h-4 rounded text-brand-600" />
          需事前登錄
        </label>
        <label class="inline-flex items-center gap-2 text-sm">
          <input type="checkbox" id="is_quota_limited" name="is_quota_limited" class="w-4 h-4 rounded text-brand-600" />
          有名額限制
        </label>
        <label class="inline-flex items-center gap-2 text-sm">
          <input type="checkbox" id="requires_plan_switch" name="requires_plan_switch" class="w-4 h-4 rounded text-brand-600" />
          切換方案 / 權益
        </label>
      </div>

      <div id="planSwitchGroup" class="hidden rounded-2xl border border-amber-200 bg-amber-50/60 p-3">
        <label class="label !text-amber-700" for="required_plan_name">需切換至哪個方案 / 權益</label>
        <input id="required_plan_name" name="required_plan_name" type="text" maxlength="255"
               class="field" placeholder="例：現金回饋方案、樂天旅遊回饋、綁定 LINE Pay" />
        <p class="text-[11px] text-amber-700/80 mt-1.5">此項會在 AI 推薦時以「支付注意事項」提醒你先完成切換。</p>
      </div>

      <div>
        <label class="label" for="description">活動規則原文備份</label>
        <textarea id="description" name="description" rows="3" class="field font-mono text-xs"></textarea>
      </div>

      <div class="flex gap-3 pt-2">
        <a href="<%= BASE_PATH %>/campaigns" class="btn-ghost flex-1">取消</a>
        <button class="btn-primary flex-1">儲存活動</button>
      </div>
    </form>
  </main>

  <script>
    (function(){
      var BASE_PATH = <%- JSON.stringify(BASE_PATH) %>;
      var qs = function(s){ return document.querySelector(s); };
      var raw = qs('#raw_text');
      var status = qs('#parseStatus');
      var btn = qs('#btnParse');
      btn.addEventListener('click', async function(){
        var text = raw.value.trim();
        if (text.length < 10) { status.textContent = '請貼上完整活動規則'; return; }
        status.textContent = 'AI 抽取中，請稍候…';
        btn.classList.add('is-loading');
        btn.disabled = true;
        try {
          var r = await fetch(BASE_PATH + '/campaigns/parse', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ raw_text: text })
          });
          var j = await r.json();
          if (!r.ok) { status.textContent = '❌ ' + (j.error || '解析失敗'); return; }
          fill(j.parsed, text);
          status.textContent = '✅ 已抽取完成，請確認欄位後儲存';
        } catch (e) {
          status.textContent = '❌ 網路錯誤';
        } finally {
          btn.classList.remove('is-loading');
          btn.disabled = false;
        }
      });
      function fill(p, original){
        qs('#campaign_name').value    = p.campaign_name || '';
        qs('#start_date').value       = p.start_date || '';
        qs('#end_date').value         = p.end_date || '';
        qs('#reward_rate').value      = p.reward_rate ?? '';
        qs('#reward_cap_amount').value = p.reward_cap_amount ?? '';
        qs('#reward_cap_period').value = p.reward_cap_period ?? 0;
        qs('#min_spend_amount').value = p.min_spend_amount ?? '';
        qs('#target_merchants').value = (p.target_merchants || []).join(', ');
        qs('#requires_registration').checked = !!p.requires_registration;
        qs('#is_quota_limited').checked      = !!p.is_quota_limited;
        qs('#requires_plan_switch').checked  = !!p.requires_plan_switch;
        qs('#required_plan_name').value      = p.required_plan_name || '';
        togglePlanSwitch();
        qs('#description').value = original.slice(0, 4000);
        document.querySelectorAll('.day-chk').forEach(function(el){ el.checked = false; });
        (p.applicable_days || []).forEach(function(d){
          var el = document.querySelector('.day-chk[data-day="' + d + '"]');
          if (el) el.checked = true;
        });
      }

      function togglePlanSwitch(){
        var on = qs('#requires_plan_switch').checked;
        var grp = qs('#planSwitchGroup');
        grp.classList.toggle('hidden', !on);
        var input = qs('#required_plan_name');
        if (!on) input.value = '';
        input.required = on;
      }
      qs('#requires_plan_switch').addEventListener('change', togglePlanSwitch);
      togglePlanSwitch();
    })();
  </script>

  <%- include('../partials/foot') %>
